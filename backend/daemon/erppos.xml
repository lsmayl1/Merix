<service>
	<id>erppos.exe</id>
	<name>ERP-POS</name>
	<description>Bu servis, Node.js uygulamamı Windows hizmeti olarak çalıştırır.</description>
	<executable>C:\Users\User\AppData\Local\nvm\v22.13.1\node.exe</executable>
	<argument>--harmony</argument>
	<argument>C:\erp_pos\backend\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>C:\erp_pos\backend\index.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>ERP-POS wrapper</argument>
	<argument>--grow</argument>
	<argument>0.25</argument>
	<argument>--wait</argument>
	<argument>1</argument>
	<argument>--maxrestarts</argument>
	<argument>3</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<serviceaccount>
		<domain>ISMAYLOV</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>C:\erp_pos\backend</workingdirectory>
</service>